{
  "name": "mollie",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:api": "pnpm --filter @reselleros/api dev",
    "dev:web": "pnpm --filter @reselleros/web dev",
    "dev:worker": "pnpm --filter @reselleros/worker dev",
    "dev:connector": "pnpm --filter @reselleros/connector-runner dev",
    "local:start": "powershell -ExecutionPolicy Bypass -File infra/scripts/mollie-local.ps1 start",
    "local:stop": "powershell -ExecutionPolicy Bypass -File infra/scripts/mollie-local.ps1 stop",
    "local:restart": "powershell -ExecutionPolicy Bypass -File infra/scripts/mollie-local.ps1 restart",
    "local:status": "powershell -ExecutionPolicy Bypass -File infra/scripts/mollie-local.ps1 status",
    "local:logs": "powershell -ExecutionPolicy Bypass -File infra/scripts/mollie-local.ps1 logs",
    "test": "tsx --test tests/**/*.test.ts",
    "test:contracts": "tsx --test tests/api/**/*.test.ts",
    "test:e2e": "node ./infra/scripts/run-e2e.mjs",
    "test:e2e:raw": "tsx --test tests/e2e/workflow.test.ts",
    "test:ui": "node ./infra/scripts/run-ui-e2e.mjs",
    "test:e2e:local": "powershell -ExecutionPolicy Bypass -File infra/scripts/test-e2e.ps1",
    "docker:smoke-build": "powershell -ExecutionPolicy Bypass -File infra/scripts/smoke-build-images.ps1",
    "docker:smoke-start": "powershell -ExecutionPolicy Bypass -File infra/scripts/smoke-start-containers.ps1",
    "deploy:validate": "powershell -ExecutionPolicy Bypass -File infra/scripts/validate-cloudrun-config.ps1",
    "catalog:seed": "pnpm --filter @reselleros/catalog-tools seed:upc-corpus",
    "catalog:crawl": "pnpm --filter @reselleros/catalog-tools crawl",
    "vendor:helper": "pnpm --filter @reselleros/automation-helper connect",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @reselleros/db db:generate",
    "db:migrate": "pnpm --filter @reselleros/db db:migrate",
    "db:seed": "pnpm --filter @reselleros/db db:seed"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "turbo": "^2.5.0",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "overrides": {
      "@tootallnate/once": "3.0.1",
      "defu": "6.1.5",
      "effect": "3.20.0"
    }
  }
}
