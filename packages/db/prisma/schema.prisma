generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MarketplacePlatform {
  EBAY
  DEPOP
  POSHMARK
  WHATNOT
}

enum MarketplaceAccountStatus {
  PENDING
  CONNECTED
  DISABLED
  ERROR
}

enum MarketplaceCredentialType {
  SECRET_REF
  OAUTH_TOKEN_SET
}

enum CredentialValidationStatus {
  UNVERIFIED
  VALID
  INVALID
  NEEDS_REFRESH
}

enum SourceLotStatus {
  PENDING
  FETCHED
  ANALYZED
  FAILED
}

enum InventoryStatus {
  DRAFT
  READY
  LISTED
  SOLD
  ARCHIVED
}

enum DraftReviewStatus {
  DRAFT
  NEEDS_REVIEW
  APPROVED
  REJECTED
}

enum PlatformListingStatus {
  PENDING
  PUBLISHED
  SYNCED
  SOLD
  ENDED
  FAILED
}

enum ExecutionStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum PayoutStatus {
  PENDING
  PAID
  DISPUTED
}

enum ImageKind {
  ORIGINAL
  DERIVED
}

enum WorkspaceRole {
  OWNER
  MEMBER
}

enum CatalogIdentifierType {
  UPC
  EAN
  ISBN
  CODE128
  UNKNOWN
}

enum CatalogTrustStatus {
  LOOKUP_DISCOVERED
  SEED_TENTATIVE
  CRAWLER_DERIVED
  OPERATOR_CONFIRMED
}

enum MarketplaceConnectAttemptState {
  PENDING
  AWAITING_LOGIN
  AWAITING_2FA
  CAPTURING_SESSION
  VALIDATING
  CONNECTED
  FAILED
  EXPIRED
}

enum InventoryImportSourceKind {
  LINKED_ACCOUNT
  CSV_EXPORT
  PUBLIC_URL
}

enum InventoryImportSourcePlatform {
  EBAY
  DEPOP
  POSHMARK
  WHATNOT
  NIFTY
  CROSSLIST
}

enum InventoryImportRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum InventoryImportItemStatus {
  PENDING
  PREVIEWED
  APPLIED
  SKIPPED
  FAILED
}

enum ExtensionTaskAction {
  IMPORT_LISTING
  PREPARE_DRAFT
  PUBLISH_LISTING
  UPDATE_LISTING
  DELIST_LISTING
  RELIST_LISTING
}

enum ExtensionTaskState {
  QUEUED
  RUNNING
  NEEDS_INPUT
  FAILED
  SUCCEEDED
  CANCELED
}

model User {
  id               String                @id @default(cuid())
  email            String                @unique
  name             String?
  createdAt        DateTime              @default(now())
  sessions         Session[]
  authChallenges   AuthChallenge[]
  workspaces       Workspace[]           @relation("WorkspaceOwner")
  memberships      WorkspaceMembership[]
  auditLogs        AuditLog[]
}

model Session {
  id               String   @id @default(cuid())
  sessionTokenHash String   @unique
  userId           String
  expiresAt        DateTime
  lastUsedAt       DateTime?
  revokedAt        DateTime?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuthChallenge {
  id             String   @id @default(cuid())
  userId         String
  email          String
  codeHash       String
  expiresAt      DateTime
  consumedAt     DateTime?
  attemptCount   Int      @default(0)
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([email, createdAt])
}

model Workspace {
  id                 String               @id @default(cuid())
  ownerUserId        String
  name               String
  plan               String               @default("pilot")
  billingCustomerId  String?
  connectorAutomationEnabled Boolean      @default(true)
  createdAt          DateTime             @default(now())
  owner              User                 @relation("WorkspaceOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  memberships        WorkspaceMembership[]
  marketplaceConnectAttempts MarketplaceConnectAttempt[]
  marketplaceAccounts MarketplaceAccount[]
  inventoryImportRuns InventoryImportRun[]
  extensionTasks     ExtensionTask[]
  sourceLots         SourceLot[]
  inventoryItems     InventoryItem[]
  catalogWorkspaceObservations WorkspaceCatalogObservation[]
  catalogWorkspaceOverrides WorkspaceCatalogOverride[]
  executionLogs      ExecutionLog[]
  auditLogs          AuditLog[]
}

model WorkspaceMembership {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId, workspaceId])
}

model MarketplaceAccount {
  id             String                   @id @default(cuid())
  workspaceId    String
  platform       MarketplacePlatform
  displayName    String
  status         MarketplaceAccountStatus @default(PENDING)
  secretRef      String
  credentialType MarketplaceCredentialType @default(SECRET_REF)
  validationStatus CredentialValidationStatus @default(UNVERIFIED)
  externalAccountId String?
  credentialMetadataJson Json?
  credentialPayloadJson Json?
  lastValidatedAt DateTime?
  consecutiveFailureCount Int             @default(0)
  lastFailureAt  DateTime?
  lastErrorCode  String?
  lastErrorMessage String?
  lastSyncAt     DateTime?
  createdAt      DateTime                 @default(now())
  workspace      Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  connectAttempts MarketplaceConnectAttempt[]
  importRuns      InventoryImportRun[]
  extensionTasks  ExtensionTask[]
  platformListings PlatformListing[]

  @@index([workspaceId, platform])
}

model MarketplaceConnectAttempt {
  id                 String                         @id @default(cuid())
  workspaceId        String
  marketplaceAccountId String?
  platform           MarketplacePlatform
  displayName        String
  state              MarketplaceConnectAttemptState @default(PENDING)
  helperNonce        String                         @unique
  promptsJson        Json?
  metadataJson       Json?
  externalAccountId  String?
  lastErrorCode      String?
  lastErrorMessage   String?
  expiresAt          DateTime
  createdAt          DateTime                       @default(now())
  updatedAt          DateTime                       @updatedAt
  workspace          Workspace                      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  marketplaceAccount MarketplaceAccount?           @relation(fields: [marketplaceAccountId], references: [id], onDelete: SetNull)

  @@index([workspaceId, platform, createdAt])
  @@index([workspaceId, state, expiresAt])
}

model SourceLot {
  id                    String          @id @default(cuid())
  workspaceId           String
  sourcePlatform        String          @default("MAC_BID")
  externalId            String
  title                 String
  sourceUrl             String
  rawMetadataJson       Json
  estimatedResaleMin    Float?
  estimatedResaleMax    Float?
  recommendedMaxBid     Float?
  confidenceScore       Float?
  riskScore             Float?
  analysisSummary       String?
  analysisRationaleJson Json?
  status                SourceLotStatus @default(PENDING)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  workspace             Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  inventoryItems        InventoryItem[]

  @@index([workspaceId, status])
  @@unique([workspaceId, externalId])
}

model InventoryItem {
  id                   String          @id @default(cuid())
  workspaceId          String
  sourceLotId          String?
  sku                  String
  title                String
  brand                String?
  category             String
  condition            String
  size                 String?
  color                String?
  attributesJson       Json
  imageManifestJson    Json?
  quantity             Int             @default(1)
  costBasis            Float           @default(0)
  estimatedResaleMin   Float?
  estimatedResaleMax   Float?
  priceRecommendation  Float?
  status               InventoryStatus @default(DRAFT)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  workspace            Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceLot            SourceLot?      @relation(fields: [sourceLotId], references: [id], onDelete: SetNull)
  images               ImageAsset[]
  listingDrafts        ListingDraft[]
  platformListings     PlatformListing[]
  sales                Sale[]
  executionLogs        ExecutionLog[]
  extensionTasks       ExtensionTask[]
  importedFrom         InventoryImportItem[]

  @@index([workspaceId, status])
  @@index([sourceLotId])
  @@unique([workspaceId, sku])
}

model InventoryImportRun {
  id                 String                      @id @default(cuid())
  workspaceId        String
  marketplaceAccountId String?
  sourceKind         InventoryImportSourceKind
  sourcePlatform     InventoryImportSourcePlatform
  sourceUrl          String?
  uploadFilename     String?
  status             InventoryImportRunStatus   @default(PENDING)
  cursorJson         Json?
  statsJson          Json?
  artifactUrlsJson   Json?
  progressCount      Int                         @default(0)
  appliedCount       Int                         @default(0)
  failedCount        Int                         @default(0)
  skippedCount       Int                         @default(0)
  lastErrorCode      String?
  lastErrorMessage   String?
  startedAt          DateTime?
  finishedAt         DateTime?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  workspace          Workspace                   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  marketplaceAccount MarketplaceAccount?        @relation(fields: [marketplaceAccountId], references: [id], onDelete: SetNull)
  items              InventoryImportItem[]
  extensionTasks     ExtensionTask[]

  @@index([workspaceId, createdAt])
  @@index([workspaceId, status, createdAt])
  @@index([marketplaceAccountId, createdAt])
}

model InventoryImportItem {
  id                    String                    @id @default(cuid())
  runId                  String
  matchedInventoryItemId String?
  externalItemId         String?
  sourceUrl              String?
  dedupeKey              String
  status                 InventoryImportItemStatus @default(PENDING)
  rawSourcePayloadJson   Json?
  normalizedCandidateJson Json?
  lastErrorMessage       String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  run                    InventoryImportRun        @relation(fields: [runId], references: [id], onDelete: Cascade)
  matchedInventoryItem   InventoryItem?            @relation(fields: [matchedInventoryItemId], references: [id], onDelete: SetNull)

  @@index([runId, createdAt])
  @@index([runId, status, createdAt])
  @@index([dedupeKey])
}

model ExtensionTask {
  id                  String             @id @default(cuid())
  workspaceId         String
  inventoryItemId     String?
  inventoryImportRunId String?
  marketplaceAccountId String?
  platform            MarketplacePlatform
  action              ExtensionTaskAction
  state               ExtensionTaskState @default(QUEUED)
  queuedAt            DateTime           @default(now())
  attemptCount        Int                @default(0)
  runnerInstanceId    String?
  claimedAt           DateTime?
  lastHeartbeatAt     DateTime?
  retryAfter          DateTime?
  needsInputReason    String?
  payloadJson         Json?
  resultJson          Json?
  lastErrorCode       String?
  lastErrorMessage    String?
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  workspace           Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  inventoryItem       InventoryItem?     @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  inventoryImportRun  InventoryImportRun? @relation(fields: [inventoryImportRunId], references: [id], onDelete: SetNull)
  marketplaceAccount  MarketplaceAccount? @relation(fields: [marketplaceAccountId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, state, createdAt])
  @@index([workspaceId, state, retryAfter, createdAt])
  @@index([inventoryItemId, platform, createdAt])
  @@index([inventoryImportRunId, platform, createdAt])
}

model CatalogIdentifier {
  id                   String                @id @default(cuid())
  normalizedIdentifier String                @unique
  identifierType       CatalogIdentifierType
  canonicalTitle       String?
  brand                String?
  category             String?
  canonicalImageUrlsJson Json?
  sourceReferencesJson Json?
  trustStatus          CatalogTrustStatus    @default(LOOKUP_DISCOVERED)
  confidenceScore      Float                 @default(0)
  lastConfirmedAt      DateTime?
  lastRefreshedAt      DateTime?
  lastLookupAt         DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  observations         CatalogObservation[]
  workspaceObservations WorkspaceCatalogObservation[]
  workspaceOverrides   WorkspaceCatalogOverride[]

  @@index([identifierType, updatedAt])
}

model CatalogObservation {
  id                  String             @id @default(cuid())
  catalogIdentifierId String
  market              String
  label               String
  price               Float?
  sourceUrl           String?
  note                String?
  observedAt          DateTime
  imageUrlsJson       Json?
  provenance          CatalogTrustStatus @default(CRAWLER_DERIVED)
  confidenceScore     Float?
  createdAt           DateTime           @default(now())
  catalogIdentifier   CatalogIdentifier  @relation(fields: [catalogIdentifierId], references: [id], onDelete: Cascade)

  @@index([catalogIdentifierId, observedAt])
}

model WorkspaceCatalogObservation {
  id                  String            @id @default(cuid())
  workspaceId         String
  catalogIdentifierId String
  market              String
  label               String
  price               Float?
  sourceUrl           String?
  note                String?
  observedAt          DateTime
  createdAt           DateTime          @default(now())
  workspace           Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  catalogIdentifier   CatalogIdentifier @relation(fields: [catalogIdentifierId], references: [id], onDelete: Cascade)

  @@index([workspaceId, observedAt])
  @@index([catalogIdentifierId, observedAt])
}

model WorkspaceCatalogOverride {
  id                  String            @id @default(cuid())
  workspaceId         String
  catalogIdentifierId String
  title               String?
  brand               String?
  category            String?
  imageUrlsJson       Json?
  lastConfirmedAt     DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  workspace           Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  catalogIdentifier   CatalogIdentifier @relation(fields: [catalogIdentifierId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, catalogIdentifierId])
  @@index([workspaceId, updatedAt])
}

model ImageAsset {
  id              String        @id @default(cuid())
  inventoryItemId String
  url             String
  kind            ImageKind     @default(ORIGINAL)
  width           Int?
  height          Int?
  position        Int           @default(0)
  createdAt       DateTime      @default(now())
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([inventoryItemId, position])
}

model ListingDraft {
  id                   String            @id @default(cuid())
  inventoryItemId      String
  platform             MarketplacePlatform
  generatedTitle       String
  generatedDescription String
  generatedPrice       Float
  generatedTagsJson    Json
  attributesJson       Json
  reviewStatus         DraftReviewStatus @default(NEEDS_REVIEW)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  inventoryItem        InventoryItem     @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([inventoryItemId, platform])
}

model PlatformListing {
  id                  String                @id @default(cuid())
  inventoryItemId     String
  marketplaceAccountId String
  platform            MarketplacePlatform
  externalListingId   String?
  status              PlatformListingStatus @default(PENDING)
  publishedTitle      String?
  publishedPrice      Float?
  externalUrl         String?
  lastSyncAt          DateTime?
  rawLastResponseJson Json?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  inventoryItem       InventoryItem         @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  marketplaceAccount  MarketplaceAccount    @relation(fields: [marketplaceAccountId], references: [id], onDelete: Cascade)
  sales               Sale[]
  executionLogs       ExecutionLog[]

  @@index([inventoryItemId, platform])
}

model Sale {
  id                String        @id @default(cuid())
  inventoryItemId   String
  platformListingId String?
  soldPrice         Float
  fees              Float         @default(0)
  shippingCost      Float?
  soldAt            DateTime
  payoutStatus      PayoutStatus  @default(PENDING)
  createdAt         DateTime      @default(now())
  inventoryItem     InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  platformListing   PlatformListing? @relation(fields: [platformListingId], references: [id], onDelete: SetNull)

  @@index([inventoryItemId, soldAt])
}

model ExecutionLog {
  id                  String          @id @default(cuid())
  workspaceId         String
  inventoryItemId     String?
  platformListingId   String?
  jobName             String
  connector           String?
  status              ExecutionStatus @default(QUEUED)
  attempt             Int             @default(1)
  correlationId       String
  requestPayloadJson  Json?
  responsePayloadJson Json?
  artifactUrlsJson    Json?
  startedAt           DateTime?
  finishedAt          DateTime?
  createdAt           DateTime        @default(now())
  workspace           Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  inventoryItem       InventoryItem?  @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  platformListing     PlatformListing? @relation(fields: [platformListingId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, jobName, status, createdAt])
  @@index([correlationId])
}

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  actorUserId String?
  action      String
  targetType  String
  targetId    String
  metadataJson Json?
  createdAt   DateTime @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actorUser   User?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([targetType, targetId])
}
